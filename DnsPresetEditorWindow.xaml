<Window x:Class="LaptopSessionViewer.DnsPresetEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DNS Preset"
        Width="420"
        Height="390"
        MinWidth="420"
        MinHeight="390"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F4EFE6"
        FontFamily="Bahnschrift">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="HeaderTextBlock"
                   FontSize="20"
                   FontWeight="Bold"
                   Foreground="#16212B" />

        <StackPanel Grid.Row="2">
            <TextBlock x:Name="NameLabel"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="#16212B" />
            <TextBox x:Name="NameTextBox"
                     Margin="0,8,0,0"
                     Padding="12,8" />
        </StackPanel>

        <StackPanel Grid.Row="4">
            <TextBlock x:Name="PrimaryLabel"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="#16212B" />
            <TextBox x:Name="PrimaryTextBox"
                     Margin="0,8,0,0"
                     Padding="12,8" />
        </StackPanel>

        <StackPanel Grid.Row="6">
            <TextBlock x:Name="SecondaryLabel"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="#16212B" />
            <TextBox x:Name="SecondaryTextBox"
                     Margin="0,8,0,0"
                     Padding="12,8" />
        </StackPanel>

        <StackPanel Grid.Row="8">
            <TextBlock x:Name="DescriptionLabel"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="#16212B" />
            <TextBox x:Name="DescriptionTextBox"
                     Margin="0,8,0,0"
                     Padding="12,8"
                     Height="72"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto" />
        </StackPanel>

        <CheckBox x:Name="DohCheckBox"
                  Grid.Row="10"
                  Foreground="#16212B"
                  Content="DoH"
                  Checked="DohCheckBox_Changed"
                  Unchecked="DohCheckBox_Changed" />

        <StackPanel x:Name="DohTemplatePanel"
                    Grid.Row="12">
            <TextBlock x:Name="DohTemplateLabel"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="#16212B" />
            <TextBox x:Name="DohTemplateTextBox"
                     Margin="0,8,0,0"
                     Padding="12,8" />
        </StackPanel>

        <StackPanel Grid.Row="14"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button x:Name="SaveButton"
                    Width="120"
                    Margin="0,0,10,0"
                    Padding="10,6"
                    Click="SaveButton_Click" />
            <Button x:Name="CancelButton"
                    Width="100"
                    Padding="10,6"
                    Background="#C8B6A4"
                    BorderBrush="#C8B6A4"
                    Foreground="#16212B"
                    Click="CancelButton_Click" />
        </StackPanel>
    </Grid>
</Window>
