<Window x:Class="LaptopSessionViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:LaptopSessionViewer"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding Strings[AppTitle]}"
        Icon="pack://application:,,,/Assets/AIHelper.ico"
        Width="1360"
        Height="740"
        MinWidth="1180"
        MinHeight="640"
        WindowStartupLocation="CenterScreen"
        Background="#F4EFE6"
        FontFamily="Bahnschrift">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <local:BindingProxy x:Key="ViewModelProxy"
                            Data="{Binding RelativeSource={RelativeSource AncestorType=Window}}" />

        <Style x:Key="MetricCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="8,7" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Background" Value="#1D3545" />
            <Setter Property="Height" Value="56" />
            <Setter Property="VerticalAlignment" Value="Top" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="#FFFDF9" />
            <Setter Property="Background" Value="#D97732" />
            <Setter Property="BorderBrush" Value="#D97732" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="TextBlock.TextAlignment" Value="Center" />
            <Setter Property="TextBlock.TextWrapping" Value="Wrap" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="14"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EA8C49" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.6" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="#FFFDF9" />
            <Setter Property="Foreground" Value="#16212B" />
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#FFFDF9" />
                    <Setter Property="Foreground" Value="#667085" />
                    <Setter Property="Opacity" Value="1" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Background" Value="#FFFDF9" />
            <Setter Property="Foreground" Value="#16212B" />
            <Setter Property="BorderThickness" Value="0" />
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#FFFDF9" />
                    <Setter Property="Foreground" Value="#667085" />
                    <Setter Property="Opacity" Value="1" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SidebarComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="FontSize" Value="12.5" />
        </Style>

        <Style x:Key="PassiveComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="Background" Value="#FFFDF9" />
            <Setter Property="BorderBrush" Value="#FFFDF9" />
            <Style.Triggers>
                <Trigger Property="IsHitTestVisible" Value="False">
                    <Setter Property="Background" Value="#FFFDF9" />
                    <Setter Property="BorderBrush" Value="#FFFDF9" />
                    <Setter Property="Foreground" Value="#667085" />
                    <Setter Property="Opacity" Value="1" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SideNavButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Padding" Value="16,12" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#16212B" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="0,0,18,10" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="SessionTabButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="128" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="156" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Padding" Value="8,5" />
        </Style>

        <Style x:Key="SetupSectionToggleButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter HorizontalAlignment="Stretch"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SetupSectionToggleButtonDarkStyle" TargetType="Button" BasedOn="{StaticResource SetupSectionToggleButtonStyle}">
            <Setter Property="Foreground" Value="#FFFDF9" />
        </Style>

        <Style x:Key="SetupSectionToggleHorizontalLineStyle" TargetType="Rectangle">
            <Setter Property="Width" Value="12" />
            <Setter Property="Height" Value="2" />
            <Setter Property="RadiusX" Value="1" />
            <Setter Property="RadiusY" Value="1" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="SetupSectionToggleVerticalLineStyle" TargetType="Rectangle">
            <Setter Property="Width" Value="2" />
            <Setter Property="Height" Value="12" />
            <Setter Property="RadiusX" Value="1" />
            <Setter Property="RadiusY" Value="1" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="SetupSectionToggleBadgeStyle" TargetType="Border">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="CornerRadius" Value="17" />
            <Setter Property="Background" Value="#ECDED0" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Top" />
        </Style>

        <Style x:Key="SetupSectionToggleBadgeDarkStyle" TargetType="Border" BasedOn="{StaticResource SetupSectionToggleBadgeStyle}">
            <Setter Property="Background" Value="#355364" />
        </Style>

        <Style x:Key="DnsMiniButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="MinWidth" Value="104" />
            <Setter Property="FontSize" Value="10.5" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Margin" Value="0,0,6,6" />
            <Setter Property="ContentTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{Binding}"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap" />
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DnsActionButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="FontSize" Value="10.5" />
            <Setter Property="Padding" Value="8,7" />
            <Setter Property="MinHeight" Value="46" />
            <Setter Property="ContentTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{Binding}"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap" />
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="SetupCheckItemTemplate">
            <Border Margin="0,0,0,12"
                    Padding="14"
                    CornerRadius="18"
                    Background="#F7F3EC">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="#16212B"
                                   Text="{Binding Title}" />
                        <TextBlock Margin="0,6,0,0"
                                   Foreground="#475467"
                                   TextWrapping="Wrap"
                                   Text="{Binding Detail}" />
                    </StackPanel>

                    <Border Grid.Column="1"
                            Margin="12,0,0,0"
                            Padding="10,4"
                            CornerRadius="12"
                            Background="{Binding AccentBrush}">
                        <TextBlock FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="#FFFDF9"
                                   Text="{Binding Status}" />
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#FFFDF9" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="RowBackground" Value="#FFFDF9" />
            <Setter Property="AlternatingRowBackground" Value="#F7F3EC" />
            <Setter Property="GridLinesVisibility" Value="None" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="CanUserResizeRows" Value="False" />
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="SelectionUnit" Value="FullRow" />
            <Setter Property="RowHeight" Value="76" />
            <Setter Property="ColumnHeaderHeight" Value="48" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#ECDED0" />
            <Setter Property="Foreground" Value="#16212B" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Foreground" Value="#16212B" />
            <Setter Property="BorderThickness" Value="0" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FDE6D3" />
                    <Setter Property="Foreground" Value="#16212B" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="190" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Padding="16"
                CornerRadius="24"
                Background="#16212B">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="18" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock FontSize="26"
                               FontWeight="Bold"
                               Foreground="#FFFDF9"
                               Text="{Binding Strings[AppTitle]}" />
                    <TextBlock Margin="0,6,0,0"
                               FontSize="11"
                               Foreground="#B7D0DA"
                               TextWrapping="Wrap"
                               Text="{Binding Strings[SidebarSubtitle]}" />
                </StackPanel>

                <StackPanel Grid.Row="2">
                    <Button Style="{StaticResource SideNavButtonStyle}"
                            Click="SessionsSectionButton_Click"
                            Background="{Binding SessionsSectionButtonBackground}"
                            BorderBrush="{Binding SessionsSectionButtonBackground}"
                            Foreground="{Binding SessionsSectionButtonForeground}"
                            Content="{Binding Strings[SectionSessionsNav]}" />
                    <Button Style="{StaticResource SideNavButtonStyle}"
                            Click="NewSessionSectionButton_Click"
                            Background="{Binding NewSessionSectionButtonBackground}"
                            BorderBrush="{Binding NewSessionSectionButtonBackground}"
                            Foreground="{Binding NewSessionSectionButtonForeground}"
                            Content="{Binding Strings[SectionNewSessionNav]}" />
                    <Button Style="{StaticResource SideNavButtonStyle}"
                            Click="SetupSectionButton_Click"
                            Background="{Binding SetupSectionButtonBackground}"
                            BorderBrush="{Binding SetupSectionButtonBackground}"
                            Foreground="{Binding SetupSectionButtonForeground}"
                            Content="{Binding Strings[SectionSetupNav]}" />
                    <Button Style="{StaticResource SideNavButtonStyle}"
                            Margin="0"
                            Click="SettingsSectionButton_Click"
                            Background="{Binding SettingsSectionButtonBackground}"
                            BorderBrush="{Binding SettingsSectionButtonBackground}"
                            Foreground="{Binding SettingsSectionButtonForeground}"
                            Content="{Binding Strings[SectionSettingsNav]}" />
                </StackPanel>

                <StackPanel Grid.Row="4">
                    <TextBlock FontSize="11"
                               Foreground="#B7D0DA"
                               Text="{Binding CurrentAppVersionText}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="2">
            <Grid Visibility="{Binding SessionsSectionVisibility}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="12"
                CornerRadius="18">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#132734" Offset="0" />
                    <GradientStop Color="#274552" Offset="0.65" />
                    <GradientStop Color="#D97732" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="6" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="6" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="280" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="#FFFDF9"
                                   Text="{Binding Strings[HeroTitle]}" />
                        <TextBlock Margin="0,4,0,0"
                                   FontSize="11"
                                   Foreground="#F8E7D6"
                                   TextWrapping="Wrap"
                                   Text="{Binding Strings[HeroSubtitle]}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                HorizontalAlignment="Right">
                        <TextBlock Margin="2,0,0,3"
                                   FontSize="12"
                                   Foreground="#FFFDF9"
                                   Text="{Binding Strings[SearchLabel]}" />
                        <TextBox Width="280"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Margin="2,2,0,0"
                                   FontSize="9"
                                   Foreground="#F8E7D6"
                                   TextTrimming="CharacterEllipsis"
                                   Text="{Binding Strings[SearchHelp]}" />
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource MetricCardStyle}">
                            <StackPanel>
                                <TextBlock FontSize="9"
                                           Foreground="#B7D0DA"
                                           Text="{Binding Strings[MetricTotalSessions]}" />
                                <TextBlock Margin="0,2,0,0"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Foreground="#FFFDF9"
                                           Text="{Binding TotalSessions}" />
                            </StackPanel>
                        </Border>

                    <Border Grid.Column="1" Style="{StaticResource MetricCardStyle}">
                        <StackPanel>
                            <TextBlock FontSize="9"
                                       Foreground="#B7D0DA"
                                       Text="{Binding Strings[MetricFavorites]}" />
                            <TextBlock Margin="0,2,0,0"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Foreground="#FFFDF9"
                                       Text="{Binding FavoriteSessions}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource MetricCardStyle}">
                        <StackPanel>
                            <TextBlock FontSize="9"
                                       Foreground="#B7D0DA"
                                       Text="{Binding Strings[MetricUpdatedToday]}" />
                            <TextBlock Margin="0,2,0,0"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Foreground="#FFFDF9"
                                       Text="{Binding UpdatedTodaySessions}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="3"
                            Margin="0"
                            Style="{StaticResource MetricCardStyle}">
                        <StackPanel>
                            <TextBlock FontSize="9"
                                       Foreground="#B7D0DA"
                                       Text="{Binding Strings[MetricMessages]}" />
                            <TextBlock Margin="0,2,0,0"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Foreground="#FFFDF9"
                                       Text="{Binding TotalMessages}" />
                        </StackPanel>
                    </Border>
                    </Grid>

                    <Grid Grid.Column="1"
                          Margin="10,0,0,0"
                          HorizontalAlignment="Right">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="156" />
                            <ColumnDefinition Width="4" />
                            <ColumnDefinition Width="156" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="4" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="4" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Button Grid.Row="0"
                                Grid.Column="0"
                                Style="{StaticResource ActionButtonStyle}"
                                Click="RefreshButton_Click"
                                IsEnabled="{Binding IsRefreshAvailable}"
                                Content="{Binding Strings[Refresh]}" />
                        <Button Grid.Row="0"
                                Grid.Column="2"
                                Style="{StaticResource ActionButtonStyle}"
                                Click="OpenSessionsFolderButton_Click"
                                Content="{Binding Strings[OpenSessionsFolder]}" />
                        <Button Grid.Row="2"
                                Grid.Column="0"
                                Style="{StaticResource ActionButtonStyle}"
                                Click="ResumeSelectedSessionButton_Click"
                                IsEnabled="{Binding CanResumeSelectedSession}"
                                Content="{Binding Strings[ResumeInTerminal]}" />
                        <Button Grid.Row="2"
                                Grid.Column="2"
                                Style="{StaticResource ActionButtonStyle}"
                                Click="ToggleFavoriteButton_Click"
                                Content="{Binding FavoriteButtonText}" />
                        <Button Grid.Row="4"
                                Grid.Column="0"
                                Style="{StaticResource ActionButtonStyle}"
                                Click="OpenSelectedFileButton_Click"
                                IsEnabled="{Binding CanOpenSelectedFile}"
                                Content="{Binding Strings[OpenSessionFile]}" />
                        <Button Grid.Row="4"
                                Grid.Column="2"
                                Style="{StaticResource ActionButtonStyle}"
                                Click="DeleteSelectedSessionButton_Click"
                                IsEnabled="{Binding CanDeleteSelectedSession}"
                                Background="#B42318"
                                BorderBrush="#B42318"
                                Content="{Binding Strings[DeleteSession]}" />
                    </Grid>
                </Grid>

                <Grid Grid.Row="4"
                      Margin="0,2,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock FontSize="10"
                               Foreground="{Binding StatusForeground}"
                               Text="{Binding StatusText}" />

                    <ProgressBar Grid.Column="2"
                                 Width="110"
                                 Height="6"
                                 IsIndeterminate="True"
                                 Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}" />

                    <TextBlock Grid.Column="3"
                               VerticalAlignment="Center"
                               FontSize="10"
                               Foreground="#F8E7D6"
                               HorizontalAlignment="Right"
                               Text="{Binding LastUpdatedText}" />
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="340" />
            </Grid.ColumnDefinitions>

            <Border Background="#FFFDF9"
                    CornerRadius="28"
                    Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource SessionTabButtonStyle}"
                                    Click="SessionsTabButton_Click"
                                    Background="{Binding SessionsTabBackground}"
                                    BorderBrush="{Binding SessionsTabBackground}"
                                    Foreground="{Binding SessionsTabForeground}"
                                    Content="{Binding SessionsTabText}" />
                            <Button Style="{StaticResource SessionTabButtonStyle}"
                                    Margin="0"
                                    Click="FavoritesTabButton_Click"
                                    Background="{Binding FavoritesTabBackground}"
                                    BorderBrush="{Binding FavoritesTabBackground}"
                                    Foreground="{Binding FavoritesTabForeground}"
                                    Content="{Binding FavoritesTabText}" />
                        </StackPanel>

                        <Border Margin="0,12,0,0"
                                Padding="12"
                                CornerRadius="16"
                                Background="#F7F3EC">
                            <StackPanel>
                                <TextBlock FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="#16212B"
                                           Text="{Binding Strings[SessionsGuideTitle]}" />
                                <TextBlock Margin="0,6,0,0"
                                           Foreground="#475467"
                                           TextWrapping="Wrap"
                                           Text="{Binding Strings[SessionsGuideText]}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <Grid Grid.Row="2">
                        <DataGrid ItemsSource="{Binding Sessions}"
                                  SelectedItem="{Binding SelectedSession, Mode=TwoWay}">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Width="*"
                                                        Header="{Binding Data.Strings[GridSession], Source={StaticResource ViewModelProxy}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,6,0,0">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock FontWeight="SemiBold"
                                                               Text="{Binding DisplayTitle}" />
                                                    <Border Margin="8,0,0,0"
                                                            Padding="8,2"
                                                            CornerRadius="10"
                                                            Background="#FDE8C8"
                                                            Visibility="{Binding IsFavorite, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                        <TextBlock FontSize="11"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#9A5A00"
                                                                   Text="{Binding FavoriteBadgeText}" />
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Margin="0,4,0,0"
                                                           FontSize="12"
                                                           Foreground="#667085"
                                                           Text="{Binding SecondaryTitle}"
                                                           Visibility="{Binding HasSecondaryTitle, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                <TextBlock Margin="0,6,0,0"
                                                           FontSize="12"
                                                           Foreground="#667085"
                                                           Text="{Binding ShortSessionId}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Width="150"
                                                    Binding="{Binding UpdatedAtText}"
                                                    Header="{Binding Data.Strings[GridUpdated], Source={StaticResource ViewModelProxy}}" />
                                <DataGridTextColumn Width="78"
                                                    Binding="{Binding TotalMessageCount}"
                                                    Header="{Binding Data.Strings[GridMessages], Source={StaticResource ViewModelProxy}}" />
                                <DataGridTextColumn Width="78"
                                                    Binding="{Binding ToolCallCount}"
                                                    Header="{Binding Data.Strings[GridTools], Source={StaticResource ViewModelProxy}}" />
                                <DataGridTextColumn Width="92"
                                                    Binding="{Binding ModelProvider}"
                                                    Header="{Binding Data.Strings[GridModel], Source={StaticResource ViewModelProxy}}" />
                                <DataGridTextColumn Width="92"
                                                    Binding="{Binding Source}"
                                                    Header="{Binding Data.Strings[GridSource], Source={StaticResource ViewModelProxy}}" />
