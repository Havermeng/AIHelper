                                                                IsEnabled="{Binding CanApplyOpenClawModes}"
                                                                Content="{Binding Strings[SetupOpenClawApplyAdvancedButton]}" />
                                                        <Button Margin="0,0,10,10"
                                                                Click="PrepareOpenClawAlmostFullModeButton_Click"
                                                                IsEnabled="{Binding CanApplyOpenClawModes}"
                                                                Content="{Binding Strings[SetupOpenClawApplyAlmostFullButton]}" />
                                                    </WrapPanel>

                                                    <Border Padding="14"
                                                            CornerRadius="18"
                                                            Background="#16212B">
                                                        <StackPanel>
                                                            <TextBlock FontSize="13"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="#FFFDF9"
                                                                       Text="{Binding Strings[SetupOpenClawDetectedConfigTitle]}" />
                                                            <TextBlock Margin="0,8,0,0"
                                                                       Foreground="#C3D2DC"
                                                                       TextWrapping="Wrap"
                                                                       Text="{Binding OpenClawDetectedConfigText}" />
                                                        </StackPanel>
                                                    </Border>

                                                    <Border Margin="0,12,0,0"
                                                            Padding="14"
                                                            CornerRadius="18"
                                                            Background="#203543">
                                                        <StackPanel>
                                                            <TextBlock FontSize="13"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="#FFFDF9"
                                                                       Text="{Binding Strings[SetupOpenClawRecommendationTitle]}" />
                                                            <TextBlock Margin="0,8,0,0"
                                                                       Foreground="#C3D2DC"
                                                                       TextWrapping="Wrap"
                                                                       Text="{Binding OpenClawRecommendationText}" />
                                                        </StackPanel>
                                                    </Border>

                                                    <TextBlock Margin="0,18,0,0"
                                                               FontSize="16"
                                                               FontWeight="Bold"
                                                               Foreground="#16212B"
                                                               Text="{Binding Strings[SetupOpenClawCapabilitiesTitle]}" />
                                                    <TextBlock Margin="0,6,0,0"
                                                               Foreground="#475467"
                                                               TextWrapping="Wrap"
                                                               Text="{Binding Strings[SetupOpenClawCapabilitiesSubtitle]}" />

                                                    <ItemsControl Margin="0,12,0,0"
                                                                  ItemsSource="{Binding OpenClawCapabilityChecks}"
                                                                  ItemTemplate="{StaticResource SetupCheckItemTemplate}" />

                                                    <TextBlock Margin="0,6,0,0"
                                                               FontSize="13"
                                                               FontWeight="SemiBold"
                                                               Foreground="#16212B"
                                                               Text="{Binding Strings[SetupOpenClawActionsTitle]}" />
                                                    <TextBlock Margin="0,6,0,0"
                                                               Foreground="#475467"
                                                               TextWrapping="Wrap"
                                                               Text="{Binding Strings[SetupOpenClawActionsSubtitle]}" />

                                                    <WrapPanel Margin="0,12,0,0"
                                                               ItemHeight="40"
                                                               ItemWidth="196">
                                                        <Button Margin="0,0,10,10"
                                                                Click="OpenClawStatusButton_Click"
                                                                IsEnabled="{Binding CanInspectOpenClawStatus}"
                                                                Content="{Binding Strings[SetupOpenClawStatusButton]}" />
                                                        <Button Margin="0,0,10,10"
                                                                Click="OpenClawConfigButton_Click"
                                                                IsEnabled="{Binding CanOpenOpenClawConfig}"
                                                                Content="{Binding Strings[SetupOpenClawConfigButton]}" />
                                                        <Button Margin="0,0,10,10"
                                                                Click="InstallOpenClawNodeButton_Click"
                                                                IsEnabled="{Binding CanInstallOpenClawNode}"
                                                                Content="{Binding Strings[SetupOpenClawNodeInstallButton]}" />
                                                        <Button Margin="0,0,10,10"
                                                                Click="OpenClawNodeStatusButton_Click"
                                                                IsEnabled="{Binding CanInspectOpenClawNode}"
                                                                Content="{Binding Strings[SetupOpenClawNodeStatusButton]}" />
                                                        <Button Margin="0,0,10,0"
                                                                Click="OpenClawBrowserStatusButton_Click"
                                                                IsEnabled="{Binding CanInspectOpenClawBrowser}"
                                                                Content="{Binding Strings[SetupOpenClawBrowserStatusButton]}" />
                                                    </WrapPanel>

                                                    <Border Margin="0,14,0,0"
                                                            Padding="14"
                                                            CornerRadius="18"
                                                            Background="#16212B">
                                                        <StackPanel>
                                                            <TextBlock FontSize="13"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="#FFFDF9"
                                                                       Text="{Binding Strings[SetupOpenClawNoteTitle]}" />
                                                            <TextBlock Margin="0,8,0,0"
                                                                       Foreground="#C3D2DC"
                                                                       TextWrapping="Wrap"
                                                                       Text="{Binding Strings[SetupOpenClawNote]}" />
                                                        </StackPanel>
                                                    </Border>
                                                </StackPanel>
                                            </Border>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2"
                            Background="#16212B"
                            CornerRadius="28"
                            Padding="20">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <Border Padding="16"
                                        CornerRadius="22"
                                        Background="#203543">
                                    <StackPanel>
                                        <Button Style="{StaticResource SetupSectionToggleButtonDarkStyle}"
                                                Click="ToggleSetupDnsSectionButton_Click">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="46" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Margin="0,0,14,0">
                                                    <TextBlock FontSize="18"
                                                               FontWeight="Bold"
                                                               Foreground="#FFFDF9"
                                                               Text="{Binding Strings[DnsTitle]}" />
                                                    <TextBlock Margin="0,10,0,0"
                                                               Foreground="#C3D2DC"
                                                               TextWrapping="Wrap"
                                                               Text="{Binding Strings[DnsSubtitle]}" />
                                                </StackPanel>
                                                <Border Grid.Column="1"
                                                        Style="{StaticResource SetupSectionToggleBadgeDarkStyle}">
                                                    <Grid>
                                                        <Rectangle Style="{StaticResource SetupSectionToggleHorizontalLineStyle}"
                                                                   Fill="#FFFDF9" />
                                                        <Rectangle Style="{StaticResource SetupSectionToggleVerticalLineStyle}"
                                                                   Fill="#FFFDF9"
                                                                   Visibility="{Binding SetupDnsSectionCollapsedIndicatorVisibility}" />
                                                    </Grid>
                                                </Border>
                                            </Grid>
                                        </Button>

                                        <StackPanel Margin="0,14,0,0"
                                                    Visibility="{Binding SetupDnsSectionContentVisibility}">

                                        <TextBlock Margin="0,16,0,0"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="#FFFDF9"
                                                   Text="{Binding Strings[DnsAdapterLabel]}" />
                                        <ComboBox Margin="0,8,0,0"
                                                  ItemsSource="{Binding DnsAdapters}"
                                                  SelectedItem="{Binding SelectedDnsAdapter, Mode=TwoWay}"
                                                  DisplayMemberPath="DisplayName" />

                                        <TextBlock Margin="0,16,0,0"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="#FFFDF9"
                                                   Text="{Binding Strings[DnsCurrentServersLabel]}" />
                                        <TextBlock Margin="0,6,0,0"
                                                   Foreground="#C3D2DC"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding SelectedDnsAdapterServersText}" />

                                        <TextBlock Margin="0,16,0,0"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="#FFFDF9"
                                                   Text="{Binding Strings[DnsPresetLabel]}" />
                                        <ComboBox Margin="0,8,0,0"
                                                  ItemsSource="{Binding DnsPresets}"
                                                  SelectedItem="{Binding SelectedDnsPreset, Mode=TwoWay}"
                                                  DisplayMemberPath="Name" />
                                        <TextBlock Margin="0,8,0,0"
                                                   Foreground="#9FB7C5"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding SelectedDnsPresetDescriptionText}" />

                                        <WrapPanel Margin="0,10,0,0">
                                            <Button Style="{StaticResource DnsMiniButtonStyle}"
                                                    Click="AddDnsPresetButton_Click"
                                                    Content="{Binding Strings[DnsAddPresetButton]}" />
                                            <Button Style="{StaticResource DnsMiniButtonStyle}"
                                                    Click="EditDnsPresetButton_Click"
                                                    IsEnabled="{Binding CanEditSelectedDnsPreset}"
                                                    Content="{Binding Strings[DnsEditPresetButton]}" />
                                            <Button Style="{StaticResource DnsMiniButtonStyle}"
                                                    Click="DuplicateDnsPresetButton_Click"
                                                    Content="{Binding Strings[DnsDuplicatePresetButton]}" />
                                            <Button Style="{StaticResource DnsMiniButtonStyle}"
                                                    Click="DeleteDnsPresetButton_Click"
                                                    IsEnabled="{Binding CanDeleteSelectedDnsPreset}"
                                                    Content="{Binding Strings[DnsDeletePresetButton]}" />
                                            <Button Style="{StaticResource DnsMiniButtonStyle}"
                                                    Click="ImportDnsPresetsButton_Click"
                                                    Content="{Binding Strings[DnsImportButton]}" />
                                            <Button Style="{StaticResource DnsMiniButtonStyle}"
                                                    Click="ExportDnsPresetsButton_Click"
                                                    Content="{Binding Strings[DnsExportButton]}" />
                                        </WrapPanel>

                                        <Grid Margin="0,16,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="10" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel>
                                                <TextBlock FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="#FFFDF9"
                                                           Text="{Binding Strings[DnsPrimaryLabel]}" />
                                                <TextBox Margin="0,8,0,0"
                                                         IsEnabled="{Binding CanEditDnsFields}"
                                                         Text="{Binding PrimaryDnsServer, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>

                                            <StackPanel Grid.Column="2">
                                                <TextBlock FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="#FFFDF9"
                                                           Text="{Binding Strings[DnsSecondaryLabel]}" />
                                                <TextBox Margin="0,8,0,0"
                                                         IsEnabled="{Binding CanEditDnsFields}"
                                                         Text="{Binding SecondaryDnsServer, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                        </Grid>

                                        <CheckBox Margin="0,14,0,0"
                                                  Foreground="#FFFDF9"
                                                  IsChecked="{Binding DnsUseDoh, Mode=TwoWay}"
                                                  Content="{Binding Strings[DnsUseDohLabel]}" />

                                        <StackPanel Margin="0,4,0,0"
                                                    Visibility="{Binding DnsDohTemplateVisibility}">
                                            <TextBlock FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="#FFFDF9"
                                                       Text="{Binding Strings[DnsDohTemplateLabel]}" />
                                            <TextBox Margin="0,8,0,0"
                                                     Text="{Binding DnsDohTemplate, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>

                                        <Grid Margin="0,16,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="10" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="10" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <Button Grid.Column="0"
                                                    Style="{StaticResource DnsActionButtonStyle}"
                                                    Click="ApplySelectedDnsPresetButton_Click"
                                                    IsEnabled="{Binding CanApplyDnsPreset}"
                                                    Content="{Binding Strings[DnsApplySelectedPresetButton]}" />
                                            <Button Grid.Column="2"
                                                    Style="{StaticResource DnsActionButtonStyle}"
                                                    Click="ResetAutomaticDnsButton_Click"
                                                    IsEnabled="{Binding CanResetDnsAutomatic}"
                                                    Content="{Binding Strings[DnsResetButton]}" />
                                            <Button Grid.Column="4"
                                                    Style="{StaticResource DnsActionButtonStyle}"
                                                    Click="RefreshDnsAdaptersButton_Click"
                                                    IsEnabled="{Binding CanRefreshDnsAdapters}"
                                                    Content="{Binding Strings[DnsRefreshButton]}" />
                                        </Grid>

                                        <Button Margin="0,10,0,0"
                                                Style="{StaticResource DnsActionButtonStyle}"
                                                Click="RestoreDnsBackupButton_Click"
                                                IsEnabled="{Binding CanRestorePreviousDns}"
                                                Content="{Binding Strings[DnsRestoreButton]}" />

                                            <ProgressBar Margin="0,16,0,0"
                                                         Height="8"
                                                         IsIndeterminate="True"
                                                         Visibility="{Binding IsDnsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                            <TextBlock Margin="0,12,0,0"
                                                       Foreground="{Binding DnsStatusForeground}"
                                                       TextWrapping="Wrap"
                                                       Text="{Binding DnsStatusText}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Grid>

            <Grid Visibility="{Binding SettingsSectionVisibility}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Padding="18"
                        CornerRadius="24">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#132734" Offset="0" />
                            <GradientStop Color="#274552" Offset="0.65" />
                            <GradientStop Color="#D97732" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>

                    <StackPanel>
                        <TextBlock FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="#FFFDF9"
                                   Text="{Binding Strings[SettingsTitle]}" />
                        <TextBlock Margin="0,6,0,0"
                                   FontSize="12"
                                   Foreground="#F8E7D6"
                                   TextWrapping="Wrap"
                                   Text="{Binding Strings[SettingsSubtitle]}" />
                        <StackPanel Margin="0,16,0,0"
                                    Orientation="Horizontal">
                            <Button Style="{StaticResource SessionTabButtonStyle}"
                                    Click="NeuralSettingsTabButton_Click"
                                    Background="{Binding NeuralSettingsTabBackground}"
                                    BorderBrush="{Binding NeuralSettingsTabBackground}"
                                    Foreground="{Binding NeuralSettingsTabForeground}"
                                    Content="{Binding Strings[SettingsNeuralTab]}" />
                            <Button Style="{StaticResource SessionTabButtonStyle}"
                                    Click="AppSettingsTabButton_Click"
                                    Background="{Binding AppSettingsTabBackground}"
                                    BorderBrush="{Binding AppSettingsTabBackground}"
                                    Foreground="{Binding AppSettingsTabForeground}"
                                    Content="{Binding Strings[SettingsAppTab]}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="370" />
                    </Grid.ColumnDefinitions>

                    <Border Background="#FFFDF9"
                            CornerRadius="28"
                            Padding="20">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <Grid>
                                <StackPanel Visibility="{Binding NeuralSettingsTabVisibility}">
                                    <TextBlock FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="#16212B"
                                               Text="{Binding Strings[SettingsNeuralTitle]}" />
                                    <TextBlock Margin="0,8,0,0"
                                               Foreground="#475467"
                                               TextWrapping="Wrap"
                                               Text="{Binding Strings[SettingsNeuralSubtitle]}" />

                                    <Border Margin="0,18,0,0"
                                            Padding="16"
                                            CornerRadius="22"
                                            Background="#F7F3EC">
                                        <StackPanel>
                                            <TextBlock FontSize="16"
                                                       FontWeight="Bold"
                                                       Foreground="#16212B"
                                                       Text="{Binding Strings[SettingsDangerousAccessTitle]}" />
                                            <TextBlock Margin="0,8,0,0"
                                                       Foreground="#475467"
                                                       TextWrapping="Wrap"
                                                       Text="{Binding Strings[SettingsDangerousAccessHelp]}" />
                                            <CheckBox Margin="0,14,0,0"
                                                      IsChecked="{Binding SettingsDangerousFullAccess, Mode=TwoWay}"
                                                      Content="{Binding Strings[SettingsDangerousAccessToggle]}" />
                                            <Button Margin="0,10,0,0"
                                                    Click="ApplyDangerousAccessSettingsButton_Click"
                                                    Content="{Binding Strings[SettingsDangerousAccessApplyButton]}" />
                                        </StackPanel>
                                    </Border>

                                    <Border Margin="0,18,0,0"
                                            Padding="16"
                                            CornerRadius="22"
                                            Background="#F7F3EC">
                                        <StackPanel>
                                            <TextBlock FontSize="16"
                                                       FontWeight="Bold"
                                                       Foreground="#16212B"
                                                       Text="{Binding Strings[SettingsPhotoPasteFixTitle]}" />
                                            <TextBlock Margin="0,8,0,0"
                                                       Foreground="#475467"
                                                       TextWrapping="Wrap"
                                                       Text="{Binding Strings[SettingsPhotoPasteFixHelp]}" />
                                            <CheckBox Margin="0,14,0,0"
                                                      IsChecked="{Binding SettingsPhotoPasteFixEnabled, Mode=TwoWay}"
                                                      Content="{Binding Strings[SettingsPhotoPasteFixToggle]}" />
                                            <Button Margin="0,10,0,0"
                                                    Click="ApplyPhotoPasteFixSettingsButton_Click"
                                                    Content="{Binding Strings[SettingsPhotoPasteFixApplyButton]}" />
                                        </StackPanel>
                                    </Border>

                                    <Border Margin="0,18,0,0"
                                            Padding="12"
                                            CornerRadius="16"
                                            Background="#16212B">
                                        <TextBlock Foreground="{Binding SettingsStatusForeground}"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding SettingsStatusText}" />
                                    </Border>
                                </StackPanel>

                                <StackPanel Visibility="{Binding AppSettingsTabVisibility}">
                                    <TextBlock FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="#16212B"
                                               Text="{Binding Strings[SettingsAppTitle]}" />
                                    <TextBlock Margin="0,8,0,0"
                                               Foreground="#475467"
                                               TextWrapping="Wrap"
                                               Text="{Binding Strings[SettingsAppSubtitle]}" />

                                    <Border Margin="0,18,0,0"
                                            Padding="16"
                                            CornerRadius="22"
                                            Background="#F7F3EC">
                                        <StackPanel>
                                            <TextBlock FontSize="16"
                                                       FontWeight="Bold"
                                                       Foreground="#16212B"
                                                       Text="{Binding Strings[SettingsLanguageTitle]}" />
                                            <TextBlock Margin="0,8,0,0"
                                                       Foreground="#475467"
                                                       TextWrapping="Wrap"
                                                       Text="{Binding Strings[SettingsLanguageHelp]}" />
                                            <TextBlock Margin="0,14,0,0"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="#16212B"
                                                       Text="{Binding Strings[LanguageLabel]}" />
                                            <ComboBox Margin="0,8,0,0"
                                                      ItemsSource="{Binding LanguageOptions}"
                                                      SelectedItem="{Binding SelectedLanguageOption, Mode=TwoWay}"
                                                      DisplayMemberPath="DisplayName" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </ScrollViewer>
                    </Border>

                    <Border Grid.Column="2"
                            Background="#16212B"
                            CornerRadius="28"
                            Padding="20">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <Grid>
                                <StackPanel Visibility="{Binding NeuralSettingsTabVisibility}">
                                    <TextBlock FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="#FFFDF9"
                                               Text="{Binding Strings[SettingsNeuralInfoTitle]}" />
                                    <Border Margin="0,14,0,0"
                                            Padding="16"
                                            CornerRadius="20"
                                            Background="#1D3545">
                                        <TextBlock Foreground="#E9EEF2"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding Strings[SettingsNeuralInfoBody]}" />
                                    </Border>
                                </StackPanel>

                                <StackPanel Visibility="{Binding AppSettingsTabVisibility}">
                                    <TextBlock FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="#FFFDF9"
                                               Text="{Binding Strings[UpdateTitle]}" />

                                    <Grid Margin="0,14,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="8" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="8" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="8" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="#9FB7C5"
                                                   Text="{Binding Strings[UpdateCurrentVersionLabel]}" />
                                        <TextBlock Grid.Column="2"
                                                   Foreground="#FFFDF9"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding CurrentAppVersionText}" />

                                        <TextBlock Grid.Row="2"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="#9FB7C5"
                                                   Text="{Binding Strings[UpdateLatestVersionLabel]}" />
                                        <TextBlock Grid.Row="2"
                                                   Grid.Column="2"
                                                   Foreground="#FFFDF9"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding LatestAppVersionText}" />

                                        <TextBlock Grid.Row="4"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="#9FB7C5"
                                                   Text="{Binding Strings[UpdateReleaseTitleLabel]}" />
                                        <TextBlock Grid.Row="4"
                                                   Grid.Column="2"
                                                   Foreground="#FFFDF9"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding UpdateReleaseTitleText}" />

                                        <TextBlock Grid.Row="6"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="#9FB7C5"
                                                   Text="{Binding Strings[UpdatePublishedLabel]}" />
                                        <TextBlock Grid.Row="6"
                                                   Grid.Column="2"
                                                   Foreground="#FFFDF9"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding UpdatePublishedText}" />
                                    </Grid>

                                    <Button Margin="0,16,0,0"
                                            Click="CheckForUpdatesButton_Click"
                                            IsEnabled="{Binding CanCheckForUpdates}"
                                            Content="{Binding Strings[UpdateCheckButton]}" />
                                    <Button Margin="0,10,0,0"
                                            Click="DownloadUpdateButton_Click"
                                            IsEnabled="{Binding CanDownloadUpdate}"
                                            Content="{Binding Strings[UpdateDownloadButton]}" />
                                    <Button Margin="0,10,0,0"
                                            Click="OpenReleasePageButton_Click"
                                            IsEnabled="{Binding CanOpenReleasePage}"
                                            Content="{Binding Strings[UpdateOpenReleaseButton]}" />

                                    <ProgressBar Margin="0,16,0,0"
                                                 Height="8"
                                                 IsIndeterminate="True"
                                                 Visibility="{Binding IsUpdateBusy, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                    <TextBlock Margin="0,12,0,0"
                                               Foreground="{Binding UpdateStatusForeground}"
                                               TextWrapping="Wrap"
                                               Text="{Binding UpdateStatusText}" />
                                </StackPanel>
                            </Grid>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Grid>
    </Grid>
</Grid>
</Window>




